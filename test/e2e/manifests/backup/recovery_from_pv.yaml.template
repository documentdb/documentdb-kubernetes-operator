apiVersion: documentdb.io/preview
kind: DocumentDB
metadata:
  name: ${NAME}
  namespace: ${NAMESPACE}
spec:
  nodeCount: 1
  instancesPerNode: ${INSTANCES}
  image:
    documentDB: ${DOCUMENTDB_IMAGE}
    gateway: ${GATEWAY_IMAGE}
  documentDbCredentialSecret: ${CREDENTIAL_SECRET}
  resource:
    storage:
      pvcSize: ${STORAGE_SIZE}
      storageClass: ${STORAGE_CLASS}
  exposeViaService:
    serviceType: ${EXPOSURE_TYPE}
  bootstrap:
    recovery:
      persistentVolume:
        name: ${PV_NAME}
