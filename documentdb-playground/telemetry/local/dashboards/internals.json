{
  "title": "DocumentDB Internals - Container & Pod Resources",
  "description": "Container CPU / memory / filesystem and pod network from the OTel sidecar's kubeletstats receiver.",
  "uid": "documentdb-internals",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["documentdb", "internals", "kubeletstats"],
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "current": { "selected": false, "text": "documentdb-preview-ns", "value": "documentdb-preview-ns" },
        "query": "documentdb-preview-ns",
        "hide": 2
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(k8s_container_cpu_usage{k8s_namespace_name=\"$namespace\"}, k8s_pod_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Container CPU & Memory",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Container CPU usage (cores)",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (k8s_container_cpu_usage{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container memory working set (bytes)",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (k8s_container_memory_working_set{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container memory RSS (bytes)",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (k8s_container_memory_rss{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container memory limit utilization",
      "description": "Working-set memory as a fraction of the container's memory limit. Only present for containers with limits configured.",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "k8s_container_memory_limit_utilization{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"}",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pod Network",
      "id": 6,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Network bytes received (per pod)",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name) (rate(k8s_pod_network_io{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\", direction=\"receive\"}[1m]))",
          "legendFormat": "{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network bytes transmitted (per pod)",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name) (rate(k8s_pod_network_io{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\", direction=\"transmit\"}[1m]))",
          "legendFormat": "{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Filesystem",
      "id": 9,
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Container filesystem usage (bytes)",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (k8s_container_filesystem_usage{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods reporting kubeletstats",
      "description": "Count of distinct pods reporting kubeletstats CPU usage in this namespace. Should equal the DocumentDB cluster size.",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "expr": "count(count by (k8s_pod_name) (k8s_container_cpu_usage{k8s_namespace_name=\"$namespace\"}))",
          "refId": "A"
        }
      ]
    }
  ]
}
