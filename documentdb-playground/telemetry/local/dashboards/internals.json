{
  "title": "DocumentDB Internals - Container & Pod Resources",
  "description": "Container CPU / memory / filesystem and pod network from the OTel sidecar's kubeletstats receiver.",
  "uid": "documentdb-internals",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["documentdb", "internals", "kubeletstats"],
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "current": { "selected": false, "text": "documentdb-preview-ns", "value": "documentdb-preview-ns" },
        "query": "documentdb-preview-ns",
        "hide": 2
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage{k8s_namespace_name=\"$namespace\"}, k8s_pod_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Container CPU & Memory",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Container CPU usage (cores)",
      "description": "Cumulative CPU consumption of each container in fractional cores (1.0 = one full core). Sourced from kubeletstats `container.cpu.usage`. Use this to spot CPU-hungry sidecars or runaway query workers.",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (container_cpu_usage{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container memory working set (bytes)",
      "description": "Working-set memory per container — the amount the kernel considers actively in use and not reclaimable under pressure. This is what the OOM killer compares against the container's memory limit.",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (container_memory_working_set_bytes{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container memory RSS (bytes)",
      "description": "Resident Set Size — anonymous (non-file-backed) memory pages held by each container. Typically lower than working set, which also includes active page cache.",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (container_memory_rss_bytes{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container memory usage (bytes)",
      "description": "Total memory consumed by the container (working set + cache). For limit-utilization, set resource limits on the DocumentDB pods and enable container.memory_limit_utilization in the kubeletstats receiver.",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (container_memory_usage_bytes{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pod Network",
      "id": 6,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Network bytes received (per pod)",
      "description": "Inbound network throughput per pod (rate of `k8s.pod.network.io` with direction=receive, 1m window). Aggregates across all pod interfaces.",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name) (rate(k8s_pod_network_io_bytes_total{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\", direction=\"receive\"}[1m]))",
          "legendFormat": "{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network bytes transmitted (per pod)",
      "description": "Outbound network throughput per pod (rate of `k8s.pod.network.io` with direction=transmit, 1m window). Useful for spotting replication or backup egress spikes.",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name) (rate(k8s_pod_network_io_bytes_total{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\", direction=\"transmit\"}[1m]))",
          "legendFormat": "{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Filesystem",
      "id": 9,
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Container filesystem usage (bytes)",
      "description": "Bytes consumed on the container's writable filesystem layer (excludes mounted PVCs). Watch for runaway logs or temp files. PVC usage is reported separately by CNPG.",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (k8s_pod_name, k8s_container_name) (container_filesystem_usage_bytes{k8s_namespace_name=\"$namespace\", k8s_pod_name=~\"$pod\"})",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods reporting kubeletstats",
      "description": "Count of distinct pods reporting kubeletstats CPU usage in this namespace. Should equal the DocumentDB cluster size.",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "expr": "count(count by (k8s_pod_name) (container_cpu_usage{k8s_namespace_name=\"$namespace\"}))",
          "refId": "A"
        }
      ]
    }
  ]
}
